# Production - Self-hosted Supabase
# Bu faylı kopyalayıb .env adlandır və dəyərləri doldur
VITE_SUPABASE_URL=https://supa.imtahan.store
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key-from-supabase-docker-env

# Google Auth (Supabase Backend tərəfindən istifadə olunur)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
